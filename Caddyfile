# Reverse proxy + HTTPS automático (Let's Encrypt) + servidor estático del SPA.
# SITE_ADDRESS lo inyecta docker-compose.prod.yml (ej: 1-2-3-4.sslip.io).
{$SITE_ADDRESS} {
	encode gzip

	# API .NET (catálogo, grafo, admin) y documentos servidos por el backend.
	handle /api/* {
		reverse_proxy backend:8080
	}
	handle /files/* {
		reverse_proxy backend:8080
	}
	handle /health {
		reverse_proxy backend:8080
	}

	# Resto: SPA estático con fallback a index.html (rutas del client-side router).
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
