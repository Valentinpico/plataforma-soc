# Producción — copiá a .env y completá. NO commitear .env (está en .gitignore).

# Postgres
POSTGRES_USER=soc
POSTGRES_PASSWORD=cambia-esto-por-algo-fuerte
POSTGRES_DB=soc

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=cambia-esto-por-algo-fuerte

# Contraseña del modo administración de la plataforma
ADMIN_PASSWORD=cambia-esto-por-algo-fuerte

# Hostname público para HTTPS (Caddy + Let's Encrypt).
# Con sslip.io es tu Elastic IP con guiones + .sslip.io. Ej: IP 3.91.22.10 ->
SITE_ADDRESS=3-91-22-10.sslip.io
